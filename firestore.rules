rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth.token.email != null
        && exists(/databases/$(database)/documents/admins/$(request.auth.token.email));
    }

    // Admins-kollektion: autentiserad användare kan läsa sitt eget dokument
    // (för att kontrollera om de är admin). Skrivning kräver admin.
    match /admins/{email} {
      allow read: if request.auth != null && request.auth.token.email == email;
      allow write: if request.auth != null && isAdmin();
    }

    // Events: publik läsning av publicerade, admin-skydd för skrivning
    match /events/{eventId} {
      allow read: if resource.data.published == true;
      allow write: if request.auth != null && isAdmin();
    }

    // Opportunities (karriärportal): samma mönster som events
    match /opportunities/{oppId} {
      allow read: if resource.data.published == true;
      allow write: if request.auth != null && isAdmin();
    }

    // Deals (kårmedlemsförmåner): publik läsning av publicerade
    match /deals/{dealId} {
      allow read: if resource.data.published == true;
      allow write: if request.auth != null && isAdmin();
    }

    // Allt annat kräver admin-tillgång
    match /{document=**} {
      allow read, write: if request.auth != null && isAdmin();
    }
  }
}
