rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // email_verified krävs: admins-dokumentet skapas INNAN mottagaren registrerat
    // sig (inbjudningsflödet). Utan verifieringskravet kan vem som helst som
    // känner till e-posten själv-registrera kontot via Auth REST API och bli
    // admin. Email-link-inloggning (invite/verify-flödet) sätter verified=true.
    function isAdmin() {
      return request.auth.token.email != null
        && request.auth.token.email_verified == true
        && exists(/databases/$(database)/documents/admins/$(request.auth.token.email));
    }

    // Defense-in-depth: klientens Zod-validering kan kringgås av en kapad
    // admin-token som skriver direkt via REST. Fält som renderas i href får
    // aldrig kunna bli t.ex. javascript:-URL:er, och published/datumfält
    // måste ha rätt typ (fel typ gör att dokument tyst försvinner ur
    // range-queries).
    function isHttpUrlOrEmpty(v) {
      return v is string && (v == '' || v.matches('https?://.*'));
    }

    // Rules kan inte loopa — sectionLinks är maxad till 4 poster och rullas ut.
    function validSectionLinks(list) {
      return list is list && list.size() <= 4
        && (list.size() < 1 || isHttpUrlOrEmpty(list[0].href))
        && (list.size() < 2 || isHttpUrlOrEmpty(list[1].href))
        && (list.size() < 3 || isHttpUrlOrEmpty(list[2].href))
        && (list.size() < 4 || isHttpUrlOrEmpty(list[3].href));
    }

    function validSettingsDoc(docId, data) {
      return (docId != 'links'
          || ((!('teknologkaren' in data) || isHttpUrlOrEmpty(data.teknologkaren))
            && (!('larv' in data) || isHttpUrlOrEmpty(data.larv))
            && (!('sectionLinks' in data) || validSectionLinks(data.sectionLinks))))
        && (docId != 'contact'
          || ((!('linkedin' in data) || isHttpUrlOrEmpty(data.linkedin))
            && (!('instagram' in data) || isHttpUrlOrEmpty(data.instagram))));
    }

    // Admins-kollektion: autentiserad användare kan läsa sitt eget dokument
    // (för att kontrollera om de är admin); admins kan lista hela kollektionen
    // (krävs av getAdmins() på /admin/admins). Skrivning kräver admin.
    // Delete: admin kan inte ta bort sig själv (skydd mot oavsiktlig utlåsning).
    match /admins/{email} {
      allow read: if request.auth != null
        && ((request.auth.token.email == email
             && request.auth.token.email_verified == true)
            || isAdmin());
      allow create, update: if request.auth != null && isAdmin();
      allow delete: if request.auth != null && isAdmin() && request.auth.token.email != email;
    }

    // Events: publik läsning av publicerade, admin kan läsa alla (inkl opublicerade)
    match /events/{eventId} {
      allow read: if resource.data.published == true || (request.auth != null && isAdmin());
      allow create, update: if request.auth != null && isAdmin()
        && request.resource.data.published is bool
        && request.resource.data.date is string
        && request.resource.data.endDate is string;
      allow delete: if request.auth != null && isAdmin();
    }

    // Career: publik läsning av publicerade, admin kan läsa alla
    match /career/{careerId} {
      allow read: if resource.data.published == true || (request.auth != null && isAdmin());
      allow create, update: if request.auth != null && isAdmin()
        && request.resource.data.published is bool
        && request.resource.data.deadline is string
        && (!('applyUrl' in request.resource.data) || isHttpUrlOrEmpty(request.resource.data.applyUrl));
      allow delete: if request.auth != null && isAdmin();
    }

    // Deals: publik läsning av publicerade, admin kan läsa alla
    match /deals/{dealId} {
      allow read: if resource.data.published == true || (request.auth != null && isAdmin());
      allow create, update: if request.auth != null && isAdmin()
        && request.resource.data.published is bool
        && (!('link' in request.resource.data) || isHttpUrlOrEmpty(request.resource.data.link))
        && (!('logoUrl' in request.resource.data) || isHttpUrlOrEmpty(request.resource.data.logoUrl));
      allow delete: if request.auth != null && isAdmin();
    }

    // Products: publik läsning av publicerade, admin kan läsa alla
    match /products/{productId} {
      allow read: if resource.data.published == true || (request.auth != null && isAdmin());
      allow create, update: if request.auth != null && isAdmin()
        && request.resource.data.published is bool;
      allow delete: if request.auth != null && isAdmin();
    }

    // Settings: publik läsning, admin-skrivning (href-fält scheme-valideras)
    match /settings/{docId} {
      allow read: if true;
      allow create, update: if request.auth != null && isAdmin()
        && validSettingsDoc(docId, request.resource.data);
      allow delete: if request.auth != null && isAdmin();
    }

    match /settings/timeline/items/{itemId} {
      allow read: if true;
      allow write: if request.auth != null && isAdmin();
    }

    // EventTypes (settings-subkollektion): publik läsning av publicerade, admin kan läsa alla
    match /settings/eventTypes/items/{itemId} {
      allow read: if resource.data.published == true || (request.auth != null && isAdmin());
      allow write: if request.auth != null && isAdmin();
    }

    // Secrets: enbart autentiserade admins
    match /secrets/{docId} {
      allow read, write: if request.auth != null && isAdmin();
    }

    // Ingen catch-all: okända kollektioner nekas för alla (default deny).
    // En admin-catch-all OR:as med reglerna ovan och skulle underminera
    // dem — t.ex. self-delete-skyddet på admins-kollektionen.
  }
}
